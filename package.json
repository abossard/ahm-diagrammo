{
  "name": "ahm-diagrammo",
  "version": "3.1.0",
  "description": "Turn the mermaid blocks in a Markdown file into good-looking themed SVGs — including Azure-portal style health-model swimlanes",
  "type": "module",
  "license": "MIT",
  "bin": {
    "diagrammo": "bin/diagrammo.mjs",
    "ahm-diagrammo": "bin/diagrammo.mjs"
  },
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mermaid",
    "diagram",
    "svg",
    "markdown",
    "swimlane",
    "azure",
    "health-model"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abossard/ahm-diagrammo.git"
  },
  "dependencies": {
    "dompurify": "3.4.12",
    "fflate": "0.8.3",
    "marked": "15.0.12"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.16.0"
  },
  "scripts": {
    "test": "node scripts/test.mjs",
    "goldens": "UPDATE_GOLDENS=1 node --test test/golden.test.mjs",
    "build:pages": "node scripts/build-pages.mjs"
  }
}
